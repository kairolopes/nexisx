# NexisX — variáveis de ambiente
# Copie para .env.local e preencha com os valores do seu projeto Supabase.

# URL pública do projeto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Chave anônima (pública) do Supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Chave service role (NUNCA expor no client — usar apenas em server actions/rotas seguras)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# URL base do site (usada em e-mails/redirects de auth)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
