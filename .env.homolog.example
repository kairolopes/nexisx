# NexisX — variáveis de homologação
# Copie para .env.homolog (não versionar) ou configure no provedor de preview (ex.: Vercel Preview).
# Aponte para um projeto Supabase de homologação (separado de produção, se possível).
# Nunca use o projeto de produção para testes de convite/dados.

# URL pública do projeto Supabase de homologação
NEXT_PUBLIC_SUPABASE_URL=https://your-homolog-project.supabase.co

# Chave anônima (pública) do projeto de homologação
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-homolog-anon-key

# Chave service role (SECRETA — nunca expor no client nem versionar)
SUPABASE_SERVICE_ROLE_KEY=your-homolog-service-role-key

# URL do ambiente de homologação (Vercel Preview ou localhost)
# Deve coincidir com o Site URL configurado no Supabase Dashboard de homologação
NEXT_PUBLIC_SITE_URL=https://nexisx-git-feat-sprint-2-admin-management.vercel.app

# Provider de IA — manter mock em homologação
AI_PROVIDER=mock
AI_PROVIDER_FALLBACK=mock
